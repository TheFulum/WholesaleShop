<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Shop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body>
    <div class="bg-black text-white py-1">
        <div class="container d-flex justify-content-between align-items-center small">
            <span><i class="bi bi-envelope"></i> MerchantGuild@gmail.com</span>
            <span><i class="bi bi-telephone"></i> +375 (29) 519-29-30</span>
        </div>
    </div>

    <header class="navbar navbar-expand-lg bg-dark shadow-sm sticky-top">
        <div class="container-fluid" style="padding: 0 15px; max-width: 1320px;">
            <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center me-4">
                <svg width="35px" height="35px" viewBox="0 0 0.8 0.8" version="1.1" xmlns="http://www.w3.org/2000/svg">

                    <path fill="#fff" d="
                        M0.4 0.05
                        L0.65 0.18
                        L0.6 0.55
                        Q0.4 0.75 0.2 0.55
                        L0.15 0.18
                        Z" />

                    <!-- Верхний круг -->
                    <circle fill="#fff" cx="0.4" cy="0.28" r="0.06" />

                    <!-- Нижний круг -->
                    <circle fill="#fff" cx="0.4" cy="0.62" r="0.04" />

                    <!-- Левое крыло -->
                    <path fill="#fff" d="
                        M0.28 0.45
                        Q0.34 0.38 0.4 0.45
                        Q0.34 0.43 0.28 0.45
                        Z" />

                    <!-- Правое крыло -->
                    <path fill="#fff" d="
                        M0.52 0.45
                        Q0.46 0.38 0.4 0.45
                        Q0.46 0.43 0.52 0.45
                        Z" />

                    <!-- Левый меч -->
                    <path fill="#fff" d="
                        M0.12 0.12
                        L0.2 0.2
                        L0.18 0.22
                        L0.1 0.14
                        Z" />

                    <!-- Правый меч -->
                    <path fill="#fff" d="
                        M0.68 0.12
                        L0.6 0.2
                        L0.62 0.22
                        L0.7 0.14
                        Z" />

                </svg>
                <span class="ms-2 fs-4 fw-bold text-white">Купеческая гильдия</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon bg-light"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item me-3">
                        <a asp-controller="Cart" asp-action="Index" class="nav-btn cart-btn position-relative">
                            <i class="bi bi-cart3"></i>
                            <span class="btn-text">Корзина</span>
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item me-3">
                            <a asp-controller="Account" asp-action="MyOrders" class="nav-btn profile-btn">
                                <i class="bi bi-person"></i>
                                <span class="btn-text">Кабинет</span>
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item me-3">
                                <a asp-controller="Account" asp-action="Admin" class="nav-btn admin-btn">
                                    <i class="bi bi-shield-lock"></i>
                                    <span class="btn-text">Админ</span>
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-btn logout-btn">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span class="btn-text">Выйти</span>
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-3">
                            <a asp-controller="Account" asp-action="Login" class="nav-btn login-btn">
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span class="btn-text">Войти</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Register" class="nav-btn register-btn">
                                <i class="bi bi-person-plus"></i>
                                <span class="btn-text">Регистрация</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <br />

    <div class="container">
        <main role="main" class="pb-3 flex-grow-1">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-expanded text-white pt-4">
        <div class="container">
            <div class="row g-4 pb-3">
                <div class="col-12 col-sm-6 col-lg-3">
                    <h5 class="footer-title">О магазине</h5>
                    <p class="footer-text mb-2">Купеческая гильдия - продуктовый онлайн-магазин с розничными и оптовыми заказами.</p>
                    <p class="footer-text mb-0"><i class="bi bi-truck"></i> Доставка по городу и самовывоз</p>
                </div>

                <div class="col-6 col-lg-2">
                    <h5 class="footer-title">Покупателям</h5>
                    <ul class="footer-list">
                        <li><a asp-controller="Home" asp-action="Index">Каталог</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">Корзина</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a asp-controller="Account" asp-action="MyOrders">Личный кабинет</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Account" asp-action="Login">Вход</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Регистрация</a></li>
                        }
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <h5 class="footer-title">Партнерам</h5>
                    <ul class="footer-list">
                        <li><a asp-controller="Account" asp-action="MyOrders">Заявка на опт</a></li>
                        <li><a asp-controller="Home" asp-action="Terms">Условия работы</a></li>
                        <li><a asp-controller="Home" asp-action="PrivacyPolicy">Политика ПДн</a></li>
                    </ul>
                </div>

                <div class="col-12 col-sm-6 col-lg-2">
                    <h5 class="footer-title">Контакты</h5>
                    <ul class="footer-list footer-contact">
                        <li><i class="bi bi-envelope"></i> MerchantGuild@gmail.com</li>
                        <li><i class="bi bi-telephone"></i> +375 (29) 519-29-30</li>
                        <li><i class="bi bi-geo-alt"></i> Минск, Беларусь</li>
                    </ul>
                </div>

                <div class="col-12 col-sm-6 col-lg-3">
                    <h5 class="footer-title">Режим работы</h5>
                    <ul class="footer-list footer-schedule">
                        <li><span>Пн-Пт</span><strong>9:00-21:00</strong></li>
                        <li><span>Сб</span><strong>10:00-20:00</strong></li>
                        <li><span>Вс</span><strong>Выходной</strong></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom py-2">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <div class="small text-white-50">© @DateTime.Now.Year Купеческая гильдия. Все права защищены.</div>
                <div class="footer-mini-links small">
                    <a asp-controller="Home" asp-action="Terms">Пользовательское соглашение</a>
                    <span>•</span>
                    <a asp-controller="Home" asp-action="PrivacyPolicy">Обработка персональных данных</a>
                </div>
            </div>
        </div>
    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
