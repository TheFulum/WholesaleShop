<div class="container py-4">
    <h1 class="mb-3">@ViewData["Title"]</h1>
    <div style="white-space: pre-line;">@ViewBag.DocumentContent</div>
    @if (ViewBag.UpdatedAt != null)
    {
        <div class="text-muted small mt-3">
            Обновлено: @(((DateTime)ViewBag.UpdatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
        </div>
    }
</div>
