@model Shop.Models.PickupPoint

@{
    ViewData["Title"] = "Добавить пункт самовывоза";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Добавить пункт самовывоза</h2>
        <a asp-action="PickupPoints" class="btn btn-outline-dark">← Назад</a>
    </div>

    <div class="card shadow-sm" style="max-width: 700px;">
        <div class="card-body">
            <form asp-action="AddPickupPoint" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Например: Пункт выдачи №1" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Адрес <span class="text-danger">*</span></label>
                    <div class="input-group mb-2">
                        <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                        <input type="text" id="addressInput" asp-for="Address" class="form-control"
                               placeholder="Нажмите на карту для выбора адреса" readonly required />
                    </div>
                    <div id="map" style="height: 320px; border: 1px solid #dee2e6; border-radius: 6px;"></div>
                    <div class="text-muted small mt-1">Кликните по карте чтобы выбрать адрес</div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="WorkingHours" class="form-label"></label>
                    <input asp-for="WorkingHours" class="form-control" placeholder="Пн-Пт 9:00-18:00" />
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+375(29)XXX-XX-XX" />
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label">Активен (отображается покупателям)</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100">Добавить</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

    <script>
        const minskCoords = [53.9045, 27.5615];
        const map = L.map('map').setView(minskCoords, 12);
        let marker = null;

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        map.on('click', function (e) {
            const { lat, lng } = e.latlng;

            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map).bindPopup('Пункт выдачи').openPopup();

            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                .then(r => r.json())
                .then(data => {
                    const a = data.address;
                    let address = '';
                    if (a.city || a.town || a.village) address += (a.city || a.town || a.village) + ', ';
                    if (a.road) address += a.road;
                    if (a.house_number) address += ' ' + a.house_number;
                    document.getElementById('addressInput').value = address.trim().replace(/,\s*$/, '');
                })
                .catch(() => {
                    document.getElementById('addressInput').value = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
                });
        });
    </script>

    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
