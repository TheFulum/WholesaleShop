@model IEnumerable<Shop.Models.WholesaleRequest>

@{
    ViewData["Title"] = "Заявки на оптовый доступ";
}

<div class="container my-4">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Админ-панель: Заявки на опт</h2>
        <div class="btn-group">
            <a asp-controller="Account" asp-action="LegalDocuments" class="btn btn-outline-dark">Документы</a>
            <a asp-controller="Account" asp-action="AdminUsers" class="btn btn-outline-dark">Пользователи</a>
            <a asp-controller="Account" asp-action="AdminOrders" class="btn btn-outline-dark">Заказы</a>
            <a asp-controller="Account" asp-action="Admin" class="btn btn-outline-dark">Товары</a>
        </div>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Пользователь</th>
                    <th>Компания</th>
                    <th>Контакт</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>@request.Id</td>
                        <td>@request.User?.Login</td>
                        <td>
                            <div>@request.CompanyName</div>
                            <div class="small text-muted">ИНН/УНП: @request.TaxId</div>
                        </td>
                        <td>
                            <div>@request.ContactPerson</div>
                            <div class="small text-muted">@request.ContactPhone</div>
                            <div class="small text-muted">@request.ContactEmail</div>
                        </td>
                        <td>
                            <span class="badge @(request.Status == "Approved" ? "bg-success" : request.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                @request.Status
                            </span>
                        </td>
                        <td>@request.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (request.Status == "Pending")
                            {
                                <div class="d-grid gap-2">
                                    <form asp-action="ApproveWholesaleRequest" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-success w-100">Одобрить</button>
                                    </form>
                                    <form asp-action="RejectWholesaleRequest" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <input type="text" name="reviewComment" class="form-control form-control-sm mb-1" placeholder="Причина (опц.)" />
                                        <button class="btn btn-sm btn-danger w-100">Отклонить</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <div class="small text-muted">Обработано</div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
