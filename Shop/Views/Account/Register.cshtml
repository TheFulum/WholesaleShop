@model Shop.Models.User

@{
    ViewData["Title"] = "Регистрация";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-lg" style="max-width: 500px; width: 100%; border-radius: 10px; margin-top: -200px !important;">
        <h3 class="text-center mb-4">Регистрация</h3>
        <form asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="form-group mb-3">
                <label for="login_field" class="form-label">Логин</label>
                <input asp-for="Login" class="form-control" id="login_field" placeholder="Введите логин" autocomplete="on" />
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label for="password_field" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" class="form-control" id="password_field" placeholder="Введите пароль" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label for="PhoneNumber" class="form-label">Номер телефона</label>
                <input asp-for="PhoneNumber" class="form-control" value="+375(" id="PhoneNumber"
                       placeholder="+375(XX)XXX-XX-XX"
                       autocomplete="off"
                       maxlength="19"
                       title="Введите номер в формате +375(XX)XXX-XX-XX" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label for="Email" class="form-label">Электронная почта</label>
                <input asp-for="Email" class="form-control" id="Email"
                       placeholder="email@example.com" autocomplete="on"
                       title="Введите действительный адрес электронной почты" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="consent-box mb-2" id="termsConsentBox">
                <div class="form-check mb-0">
                    <input asp-for="AcceptedTerms" class="form-check-input" id="AcceptedTerms" />
                    <label class="form-check-label" for="AcceptedTerms">
                        Я принимаю <a href="/Home/Terms" target="_blank">пользовательское соглашение</a>
                    </label>
                </div>
                <span asp-validation-for="AcceptedTerms" class="d-none"></span>
            </div>

            <div class="consent-box mb-4" id="privacyConsentBox">
                <div class="form-check mb-0">
                    <input asp-for="AcceptedPersonalDataProcessing" class="form-check-input" id="AcceptedPersonalDataProcessing" />
                    <label class="form-check-label" for="AcceptedPersonalDataProcessing">
                        Я согласен(на) на <a href="/Home/PrivacyPolicy" target="_blank">обработку персональных данных</a>
                    </label>
                </div>
                <span asp-validation-for="AcceptedPersonalDataProcessing" class="d-none"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Зарегистрироваться</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector('form[asp-action="Register"], form[action*="Register"]');
            const termsCheckbox = document.getElementById("AcceptedTerms");
            const privacyCheckbox = document.getElementById("AcceptedPersonalDataProcessing");
            const termsBox = document.getElementById("termsConsentBox");
            const privacyBox = document.getElementById("privacyConsentBox");

            function updateConsentHighlight() {
                if (!termsCheckbox.checked) termsBox.classList.add("consent-invalid");
                else termsBox.classList.remove("consent-invalid");

                if (!privacyCheckbox.checked) privacyBox.classList.add("consent-invalid");
                else privacyBox.classList.remove("consent-invalid");
            }

            if (!termsCheckbox.checked) termsBox.classList.add("consent-invalid");
            if (!privacyCheckbox.checked) privacyBox.classList.add("consent-invalid");

            termsCheckbox.addEventListener("change", updateConsentHighlight);
            privacyCheckbox.addEventListener("change", updateConsentHighlight);

            form.addEventListener("submit", function (e) {
                updateConsentHighlight();
                if (!termsCheckbox.checked || !privacyCheckbox.checked) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });

            // Маска телефона
            document.getElementById("PhoneNumber").addEventListener("input", function () {
                let value = this.value.replace(/\D/g, "");
                if (value.startsWith("375")) value = value.slice(3);
                if (value.length > 9) value = value.slice(0, 9);
                let formatted = "+375";
                if (value.length > 0) formatted += "(" + value.slice(0, 2);
                if (value.length >= 3) formatted += ")" + value.slice(2, 5);
                if (value.length >= 6) formatted += "-" + value.slice(5, 7);
                if (value.length >= 8) formatted += "-" + value.slice(7, 9);
                this.value = formatted;
            });

        });
    </script>

    <style>
        .consent-box {
            border: 1px solid rgba(0, 0, 0, 0.15);
            border-radius: 8px;
            padding: 10px 12px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .consent-invalid {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.15rem rgba(220, 53, 69, 0.15);
            background-color: rgba(220, 53, 69, 0.04);
        }
    </style>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
